datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String          @id @default(uuid())
  email         String          @unique
  passwordHash  String
  name          String
  avatarUrl     String?
  profileCode   String?         @unique
  bannerGradient String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  memberships   ProjectMember[]
  nodesCreated  Node[]
  activities    Activity[]
  githubAccount GitHubAccount?
}

model Project {
  id               String            @id @default(uuid())
  name             String
  description      String?
  ownerId          String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  members          ProjectMember[]
  branches         Branch[]
  activities       Activity[]
  githubRepository   GitHubRepository?
  repositoryAnalysis RepositoryAnalysis?
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  role      String   @default("MEMBER") // "OWNER" | "MEMBER"
  invitedAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Branch {
  id               String   @id @default(uuid())
  name             String
  projectId        String
  parentBranchId   String?
  githubSyncedFrom Boolean  @default(false)
  createdAt        DateTime @default(now())
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentBranch     Branch?  @relation("BranchHierarchy", fields: [parentBranchId], references: [id], onDelete: SetNull)
  childBranches    Branch[] @relation("BranchHierarchy")
  nodes            Node[]

  @@unique([projectId, name])
}

model Node {
  id             String             @id @default(uuid())
  title          String
  status         String             @default("NOT_STARTED") // "NOT_STARTED" | "IN_PROGRESS" | "COMPLETED"
  branchId       String
  authorId       String
  summary        String
  notes          String?
  nextSteps      String?
  relatedCommits String             @default("[]") // JSON stringified array of commit hashes
  completedWork  String             @default("[]") // JSON stringified array of completed tasks
  pendingWork    String             @default("[]") // JSON stringified array of pending tasks
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  isAiGenerated  Boolean            @default(false)
  branch         Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  author         User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  incoming       NodeRelationship[] @relation("NodeTo")
  outgoing       NodeRelationship[] @relation("NodeFrom")
  githubCommits  GitHubCommit[]
}

model NodeRelationship {
  id         String @id @default(uuid())
  fromNodeId String
  toNodeId   String
  fromNode   Node   @relation("NodeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode     Node   @relation("NodeTo", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@unique([fromNodeId, toNodeId])
}

model Activity {
  id         String   @id @default(uuid())
  projectId  String
  userId     String
  action     String // e.g. "created", "updated", "completed", "invited"
  entityType String // e.g. "node", "branch", "project", "member"
  entityName String // e.g. "Login UI", "feature/auth"
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── GitHub Integration Models ───────────────────────────────────────────────

model GitHubAccount {
  id             String   @id @default(uuid())
  userId         String   @unique
  githubId       Int
  githubUsername String
  accessToken    String
  avatarUrl      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GitHubRepository {
  id             String         @id @default(uuid())
  projectId      String         @unique
  repoName       String
  repoOwner      String
  repoUrl        String
  defaultBranch  String         @default("main")
  lastBranchSync DateTime?
  lastCommitSync DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  commits        GitHubCommit[]
}

model GitHubCommit {
  id           String           @id @default(uuid())
  sha          String
  message      String
  author       String
  timestamp    DateTime
  branchName   String
  repoId       String
  createdAt    DateTime         @default(now())
  repository   GitHubRepository @relation(fields: [repoId], references: [id], onDelete: Cascade)
  nodes        Node[]

  @@unique([repoId, sha])
}

model RepositoryAnalysis {
  id                    String   @id @default(uuid())
  projectId             String   @unique
  summary               String   @db.Text
  techStack             String   @default("[]") // JSON stringified array of technology strings
  structure             String   @default("{}") // JSON stringified structure overview object
  totalBranches         Int      @default(0)
  totalCommits          Int      @default(0)
  contributors          String   @default("[]") // JSON stringified array of contributor names
  lastUpdatedDate       DateTime @default(now())
  whatHasBeenBuilt      String   @default("[]") // JSON stringified array of strings
  currentlyActiveAreas  String   @default("[]") // JSON stringified array of strings
  potentialNextSteps    String   @default("[]") // JSON stringified array of strings
  firstCommitDate       DateTime?
  lastCommitDate        DateTime?
  defaultBranch         String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  project               Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
